# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Raw data (large files — re-generated by GitHub Actions)
data/raw/

# Source PDFs (large binaries — kept locally only)
data/source/

# Node
frontend/node_modules/
frontend/dist/
frontend/package-lock.json
# pipeline.json은 GitHub raw에서 직접 fetch (Cloudflare 25MB 제한 초과)
frontend/public/pipeline.json

# Dev
.env
*.local
.DS_Store

# 로컬 실행 로그/캐시 (재생성물 — git 미추적)
logs/
.wrangler/
data/cache/*.bak_*
data/cache/*.OLD_*

# analysis 재생성 산출물 (build_matrix.py가 생성)
analysis/crc_target_maturity/crc_target_maturity.*
analysis/crc_target_maturity/*heatmap*

# Claude Code internal
.claude/

# Generated data → hosted on Cloudflare R2 (frontend fetches from R2, not git).
# LLM 캐시(data/cache/)는 CI 재적용용으로 git 유지.
data/frontend/
data/parsed/
.env.r2

.dev.vars*
!.dev.vars.example
!.env.example
